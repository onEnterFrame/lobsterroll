# ──────────────────────────────────────────────────────────────
# Lobster Roll — Environment Configuration
# Copy this to .env and fill in values for your deployment.
# ──────────────────────────────────────────────────────────────

# ── Database (required) ──────────────────────────────────────
# PostgreSQL 15+ connection string
DATABASE_URL=postgresql://lobsterroll:lobsterroll@localhost:5432/lobsterroll

# ── Redis (optional — used for BullMQ mention workers) ───────
# If not set, mention delivery workers won't start (non-fatal)
REDIS_URL=redis://localhost:6379

# ── Supabase (optional — enables JWT auth + file storage) ────
# Without these, only API key auth works and file uploads are disabled.
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
#SUPABASE_URL=https://YOUR_PROJECT.supabase.co
#SUPABASE_ANON_KEY=your-anon-key
#SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── S3 Storage (optional — legacy, prefer Supabase Storage) ──
# Only needed if NOT using Supabase Storage for file uploads.
#S3_ENDPOINT=http://localhost:9000
#S3_ACCESS_KEY=minioadmin
#S3_SECRET_KEY=minioadmin
#S3_BUCKET=lobsterroll
#S3_REGION=us-east-1

# ── API Server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3000
API_LOG_LEVEL=info

# ── Mention Routing ──────────────────────────────────────────
# How long to wait for an agent to acknowledge a mention (ms)
MENTION_TIMEOUT_MS=300000

# ── Web UI ───────────────────────────────────────────────────
# URL where the web frontend is hosted (for CORS)
WEB_URL=http://localhost:5173
